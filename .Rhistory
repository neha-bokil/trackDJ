kat_A<-read.delim("/Users/nehabokil/MIT Dropbox/Neha Bokil/Page Lab/Experiments/SexDiff in Epigenomic Landscape/LibraryPreps/kat_correction_A.txt", check.names=FALSE, header=FALSE, stringsAsFactors = FALSE)
kat_B<-read.delim("/Users/nehabokil/MIT Dropbox/Neha Bokil/Page Lab/Experiments/SexDiff in Epigenomic Landscape/LibraryPreps/kat_correction_B.txt", check.names=FALSE, header=FALSE, stringsAsFactors = FALSE)
udi_barcodes<-read.delim("/Users/nehabokil/MIT Dropbox/Neha Bokil/Page Lab/all_nextflex_udi_barcodes_old.txt", stringsAsFactors = FALSE, check.names=FALSE)
View(kat_A)
colnames(kat_A)<-c("Sample", "Well","GTC_ID")
colnames(kat_B)<-c("Sample", "Well","GTC_ID")
View(udi_barcodes)
new_codes<-read.delim("/Users/nehabokil/MIT Dropbox/Neha Bokil/Page Lab/all_nextflex_udi_barcodes_new_wellInfo.txt", check.names=FALSE, stringsAsFactors = FALSE) #for well matching only
View(new_codes)
udi_barcodes$Barcode<-paste0(udi_barcodes$`P7 Index`,"-",udi_barcodes$`P5 Index`)
nrow(udi_barcodes)
nrow(new_codes)
udi_barcodes$Plate<-new_codes$Plate
udi_barcodes$Well<-new_codes$Well
View(udi_barcodes)
udi_barcodes_A<-udi_barcodes[udi_barcodes$Plate=="A",]
udi_barcodes_B<-udi_barcodes[udi_barcodes$Plate=="B",]
udi_barcodes_A_ord<-match(kat_A$Well,udi_barcodes_A$Well)
udi_barcodes_A_ord
kat_A$Barcode<-udi_barcodes_A[udi_barcodes_A,]$Barcode
udi_barcodes_A
kat_A$Barcode<-udi_barcodes_A$Barcode[udi_barcodes_A_ord]
View(kat_A)
udi_barcodes_B_ord<-match(kat_B$Well,udi_barcodes_B$Well )
kat_B$Barcode<-udi_barcodes_B$Barcode[udi_barcodes_B]
kat_B$Barcode<-udi_barcodes_B$Barcode[udi_barcodes_B]
udi_barcodes_B_ord
kat_B$Barcode<-udi_barcodes_B$Barcode[udi_barcodes_B]
colnames(udi_barcodes_B)
kat_B$Barcode<-udi_barcodes_B$Barcode[udi_barcodes_B_ord]
View(kat_B)
kat_all<-rbind(kat_A, kat_B)
View(kat_all)
write.table(kat_all, file="/Users/nehabokil/MIT Dropbox/Neha Bokil/Page Lab/Experiments/SexDiff in Epigenomic Landscape/LibraryPreps/20260129_kat_samples_corrected",
sep="\t", row.names = FALSE, quote=FALSE)
