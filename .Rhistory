covFiles =k4me3_coverageTracks, covTrackNames =c("H3K4me3_1","H3K4me3_2"), covTrackColors=c("palegreen2","green4"),
peakFiles=k4me3_peakFiles,peakTrackNames=c("P1","P2") ,peakTrackColors=c("palegreen2","green4")  ,
